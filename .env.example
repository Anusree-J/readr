# --- TRIBE backend selection ---------------------------------------------
# mock   -> synthetic tensors, no GPU needed (default)
# local  -> in-process TribeModel.from_pretrained("facebook/tribev2"), needs CUDA
# modal  -> HTTP call to a Modal GPU endpoint (see api/tribe/modal_app.py)
TRIBE_BACKEND=mock
MODAL_TRIBE_ENDPOINT=

# --- Authentication ------------------------------------------------------
# Needed for local/modal backends (Llama 3.2-3B gated access)
HF_TOKEN=

# --- Autoresearch agent --------------------------------------------------
# Anthropic key. When absent, autoresearch falls back to deterministic
# offline proposals so the loop still demonstrates keep/revert mechanics.
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-6

# --- Frontend ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGIN=http://localhost:3000
